# Supabase — your project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by the /fleet dashboard to read locked-down device tables.
# NEVER prefix this with NEXT_PUBLIC_. Found in Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basic-auth gate for /fleet (leave unset in local dev to skip the login prompt).
FLEET_USER=admin
FLEET_PASS=change-me
